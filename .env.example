# Copy to .env for local development. Do not commit .env.
# Obtain token: Telegram → @BotFather → /newbot → copy HTTP API token.

TELEGRAM_BOT_TOKEN=

# HTTP probes for local run / orchestration (default 8080)
# HEALTH_PORT=8080

# SQLite file (default: ./data/quicksave.db)
# DATABASE_PATH=

# Optional: override for staging/prod tooling (documented in docs/SECRETS.md)
# NODE_ENV=development

# JSON logs: trace | debug | info | warn | error | fatal (default: info)
# LOG_LEVEL=info

# Per-user sliding window (abuse protection). Defaults shown.
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_SAVES_PER_WINDOW=40
# RATE_LIMIT_MAX_LIST_PER_WINDOW=45

# Max characters for a saved note/link body (Telegram message limit is 4096)
# MAX_SAVE_CONTENT_LENGTH=4096
